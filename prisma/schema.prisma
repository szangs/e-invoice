// E-Invoice — Datenbankschema (PostgreSQL, DP-Standard)
// Mandantenmodul gemäß modul_Mandantenfaehig.md (Kernumfang)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Rollen: zwei Sphären (§3) ──
enum Role {
  OPERATOR_ADMIN // Betreiber-Administrator (keinem Mandanten zugeordnet)
  TENANT_ADMIN   // Mandanten-Administrator
  EDITOR         // Fach-Bearbeiter
  AREA_MANAGER   // Bereichs-Verantwortlicher
  AUDITOR        // Prüfer/Auditor
  USER           // Endnutzer
}

enum InvoiceStatus {
  NEW      // Neu
  CHECKED  // Geprüft
  EXPORTED // Exportiert
  REJECTED // Abgelehnt
}

// ── Mandant (§2) ──
model Tenant {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  street           String?
  zip              String?
  city             String?
  active           Boolean   @default(true)
  licenseExpiresAt DateTime? // leer = unbegrenzt
  licenseSerial    String?
  licensePlan      String?
  employeeCount    Int       @default(0)
  maxUsers         Int       @default(5)
  // Mandantenspezifische Schalter (§2/§8)
  aiAllowed        Boolean   @default(false)
  ipLoggingAllowed Boolean   @default(false)
  defaultLanguage  String    @default("de")
  backupEnabled    Boolean   @default(false)
  // Ende-zu-Ende-Verschlüsselung der Belege (Zero-Knowledge):
  // Der Datenschlüssel (DEK) wird IM BROWSER erzeugt und mit einem aus der
  // Kunden-Passphrase abgeleiteten Schlüssel (KEK) verpackt. Der Server kennt
  // weder Passphrase noch entpackten DEK — Belege sind für den Betreiber unlesbar.
  encryptionEnabled Boolean  @default(false)
  encSalt           String? // Salt der Schlüsselableitung (Base64)
  encWrappedDek     String? // verpackter Datenschlüssel (Base64: IV + Chiffrat)
  // E-Mail-Eingang: nur Absender dieser Domänen annehmen (kommagetrennt, leer = alle)
  mailAllowedDomains String?
  // Datensicherung (§17): Häufigkeit + Zustell-Adresse + letzte Sicherung
  backupFrequency String? // DAILY | WEEKLY | MONTHLY | YEARLY
  backupEmail     String?
  lastBackupAt    DateTime?
  // Revisionssicherer Hash-Bericht (Whitepaper-Preismodell Punkt 4): eigener,
  // schlanker Lauf — Rechnungsliste + Beleg-Hashes an eine feste Kunden-Adresse,
  // unabhängig von Sicherung/Restore. lastReportHash verkettet die Berichte
  // (wie die Audit-Hash-Kette, §18) für Fälschungssicherheit über die Zeit.
  reportEnabled   Boolean   @default(false)
  reportFrequency String? // DAILY | WEEKLY | MONTHLY | YEARLY
  reportEmail     String?
  lastReportAt    DateTime?
  lastReportHash  String?
  // Zähler für eindeutige Dokumenten-IDs (<Slug>-<laufende Nummer>, siehe
  // lib/docId.ts und Invoice.docId) — atomar hochgezählt, damit auch bei
  // gleichzeitigen Uploads keine Doppelvergabe entsteht.
  nextDocSeq       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  users            User[]
  invoices         Invoice[]
  apiTokens        ApiToken[]
}

// ── API-Token für die Browser-Extension (Rechnungs-Catcher) ──
model ApiToken {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label      String
  tokenHash  String    @unique // SHA-256 des Tokens — Klartext wird nie gespeichert
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

// ── Benutzer (§2) ──
model User {
  id              String    @id @default(cuid())
  tenantId        String? // null = Betreiber-Administrator
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  username        String    @unique // global eindeutiger technischer Name
  passwordHash    String
  role            Role      @default(USER)
  active          Boolean   @default(true)
  language        String    @default("de")
  twoFactorSecret String? // reserviert (MVP: 2FA nicht aktiv)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?
  lastSeenAt      DateTime?
  forcedLogoutAt  DateTime? // Zwangsabmeldung-ab (§10)
  invoices        Invoice[]

  // E-Mail ist PRO MANDANT eindeutig, nicht global (§2)
  @@unique([tenantId, email])
  @@index([email])
}

// ── Betreiber-Systemeinstellungen (§24), Schlüssel/Wert ──
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Revisionssichere Protokollierung mit Hash-Kette (§18) ──
model AuditLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  tenantId  String?
  actorId   String?
  actorName String
  action    String
  details   String?
  ip        String? // nur wenn Mandant zugestimmt hat (§18)
  prevHash  String
  hash      String

  @@index([tenantId, createdAt])
}

// ── Fernwartung §14A: eingebaute Bildschirmspiegelung (ohne externe Software) ──
enum SupportStatus {
  REQUESTED // angefragt
  ACTIVE    // aktiv (Einwilligung erteilt)
  ENDED     // beendet
  DECLINED  // abgelehnt
}

model SupportSession {
  id          String        @id @default(cuid())
  tenantId    String
  userId      String? // Nutzer, dessen Sicht gespiegelt wird (bei Betreiber-Anfrage erst nach Einwilligung)
  initiatedBy String // 'TENANT' | 'OPERATOR'
  status      SupportStatus @default(REQUESTED)
  createdAt   DateTime      @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
  endedBy     String?
  snapshot    String? // letzter DOM-Spiegel (maskiert, ohne Skripte)
  snapshotAt  DateTime?

  @@index([tenantId, status])
}

// ── E-Mail-Eingang (Weiterleitungs-Modell W1/W2): Protokoll aller Eingänge & Versuche ──
model MailIntake {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  tenantId    String? // null = keinem Mandanten zuordenbar (Fehlversuch)
  fromAddress String
  toAddress   String
  subject     String?
  status      String // PROCESSED | NO_ATTACHMENT | UNKNOWN_RECIPIENT | TENANT_LOCKED | ERROR
  detail      String?
  invoiceId   String?

  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// ── Einmal-Tickets für Identitätsübernahme (§12) ──
model LoginTicket {
  id               String    @id @default(cuid())
  code             String    @unique
  targetUserId     String
  impersonatorId   String?
  impersonatorName String?
  expiresAt        DateTime
  usedAt           DateTime?
}

// ── Rechnung (E-Invoice Kernentität, mandantengetrennt) ──
model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Eindeutige, lesbare Dokumenten-ID (<Slug>-<laufende Nummer>, z. B.
  // "musterfirma-000001") — für GoBD-Referenzierung außerhalb der internen
  // cuid. Nullable für Bestandsdaten vor Einführung dieses Felds (Backfill
  // per scripts/backfill-doc-ids.ts), danach immer gesetzt.
  docId         String?       @unique
  vendor        String
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  amountNet     Decimal?      @db.Decimal(12, 2)
  amountTax     Decimal?      @db.Decimal(12, 2)
  amountGross   Decimal?      @db.Decimal(12, 2)
  currency      String        @default("EUR")
  status        InvoiceStatus @default(NEW)
  tags          String?
  notes         String?
  fileName      String? // gespeicherter Dateiname unter uploads/{tenantId}/
  originalName  String?
  mimeType      String?
  encrypted     Boolean @default(false) // Datei liegt als Chiffrat (IV + AES-GCM)
  encOrigMime   String? // ursprünglicher MIME-Typ (für Anzeige nach Entschlüsselung)
  // Dubletten-Prüfung: Datei-Hash + Verweis auf das erkannte Original
  fileHash      String? // SHA-256 der Beleg-Datei
  duplicateOfId String? // gesetzt = als Dublette erkannt
  // KI-Datenerkennung: true = mindestens ein Feld wurde per KI übernommen
  // (Erstauswahl beim Scannen oder nachträglich auf der Detailseite), sonst
  // von Hand erfasst — sichtbar in der Rechnungsliste (source = "SCAN" +
  // aiAssisted zusammen zeigen dort Herkunft/Erfassungsart).
  aiAssisted    Boolean @default(false)
  // E-Rechnung (W17): erkanntes Format + Prüfergebnis + XML für die Visualisierung
  docFormat        String? // ZUGFERD | XRECHNUNG_CII | XRECHNUNG_UBL | PDF | OTHER
  xmlData          String? // eingebettetes/originales Rechnungs-XML
  validationOk     Boolean? // Pflichtfeld-Prüfung (EN 16931-Kern) bestanden?
  validationIssues String? // fehlende Pflichtangaben (kommagetrennt)
  // Rechnungsprüfung (klassischer 4-Augen-Workflow): je Schritt wer + wann
  // geprüft hat — gesetzt = erledigt, null = offen. Vom Server gestempelt
  // (angemeldeter Nutzer), nicht vom Client frei setzbar.
  checkElectronicAt  DateTime? // Elektronische Vorprüfung
  checkElectronicBy  String?
  checkFormalAt      DateTime? // Formal richtig
  checkFormalBy      String?
  checkSubstantiveAt DateTime? // Sachlich richtig
  checkSubstantiveBy String?
  checkAccountingAt  DateTime? // An Buchhaltung übergeben
  checkAccountingBy  String?
  // Zahlungsart: Lieferant zieht den Betrag selbst per Lastschrift/Abbuchung
  // ein (statt Überweisung durch uns)
  directDebitByVendor Boolean @default(false)
  source        String        @default("UPLOAD")
  // "Löschen" markiert nur — echtes Entfernen widerspräche der revisionssicheren
  // Nachvollziehbarkeit (GoBD). Gelöschte Rechnungen verschwinden aus der
  // normalen Liste, bleiben aber (inkl. Beleg-Datei) erhalten und lassen sich
  // wiederherstellen.
  deletedAt     DateTime?
  deletedBy     String?
  createdById   String?
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, invoiceDate])
  @@index([tenantId, fileHash])
  @@index([tenantId, deletedAt])
}
