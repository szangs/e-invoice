// E-Invoice — Datenbankschema (PostgreSQL, DP-Standard)
// Mandantenmodul gemäß modul_Mandantenfaehig.md (Kernumfang)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Rollen: zwei Sphären (§3) ──
enum Role {
  OPERATOR_ADMIN // Betreiber-Administrator (keinem Mandanten zugeordnet)
  TENANT_ADMIN   // Mandanten-Administrator
  EDITOR         // Fach-Bearbeiter
  AREA_MANAGER   // Bereichs-Verantwortlicher
  AUDITOR        // Prüfer/Auditor
  USER           // Endnutzer
}

enum InvoiceStatus {
  NEW      // Neu
  CHECKED  // Geprüft
  EXPORTED // Exportiert
  REJECTED // Abgelehnt
}

// ── Mandant (§2) ──
model Tenant {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  street           String?
  zip              String?
  city             String?
  active           Boolean   @default(true)
  licenseExpiresAt DateTime? // leer = unbegrenzt
  licenseSerial    String?
  licensePlan      String?
  employeeCount    Int       @default(0)
  maxUsers         Int       @default(5)
  // Mandantenspezifische Schalter (§2/§8)
  aiAllowed        Boolean   @default(false)
  ipLoggingAllowed Boolean   @default(false)
  defaultLanguage  String    @default("de")
  backupEnabled    Boolean   @default(false)
  // Ende-zu-Ende-Verschlüsselung der Belege (Zero-Knowledge):
  // Der Datenschlüssel (DEK) wird IM BROWSER erzeugt und mit einem aus der
  // Kunden-Passphrase abgeleiteten Schlüssel (KEK) verpackt. Der Server kennt
  // weder Passphrase noch entpackten DEK — Belege sind für den Betreiber unlesbar.
  encryptionEnabled Boolean  @default(false)
  encSalt           String? // Salt der Schlüsselableitung (Base64)
  encWrappedDek     String? // verpackter Datenschlüssel (Base64: IV + Chiffrat)
  // E-Mail-Eingang: nur Absender dieser Domänen annehmen (kommagetrennt, leer = alle)
  mailAllowedDomains String?
  // Datensicherung (§17): Häufigkeit + Zustell-Adresse + letzte Sicherung
  backupFrequency String? // DAILY | WEEKLY | MONTHLY | YEARLY
  backupEmail     String?
  lastBackupAt    DateTime?
  // Sicherungs-Umstellung (Stefan 2026-07-08): die Sicherung wird nicht mehr
  // als E-Mail-Anhang verschickt, sondern als ZIP-Paket (Hash + alle
  // Belegdateien) serverseitig abgelegt — die E-Mail enthält nur noch einen
  // Download-Link (siehe BackupPackage). backupReminderDays steuert, wie
  // lange erinnert wird, solange das Paket noch nicht heruntergeladen wurde
  // (0/leer = keine Erinnerung).
  backupReminderDays Int? @default(14)
  // Optionales externes Sicherungsziel per WebDAV (z. B. Nextcloud/ownCloud;
  // "klassisches" WebDAV-fähiges OneDrive for Business/SharePoint geht
  // ebenfalls — das moderne OneDrive-Verbraucherprodukt bietet KEIN WebDAV
  // mehr an, siehe Hinweistext in der Mandanten-Einstellungs-UI). Passwort
  // hier bewusst einfach als Text abgelegt wie die übrigen Mandanten-
  // Einstellungen dieser App — für ein produktives Setup mit hohem
  // Schutzbedarf sollte das Feld zusätzlich verschlüsselt werden.
  backupWebdavUrl  String?
  backupWebdavUser String?
  backupWebdavPass String?
  backupPackages   BackupPackage[]
  // Revisionssicherer Hash-Bericht (Whitepaper-Preismodell Punkt 4): eigener,
  // schlanker Lauf — Rechnungsliste + Beleg-Hashes an eine feste Kunden-Adresse,
  // unabhängig von Sicherung/Restore. lastReportHash verkettet die Berichte
  // (wie die Audit-Hash-Kette, §18) für Fälschungssicherheit über die Zeit.
  reportEnabled   Boolean   @default(false)
  reportFrequency String? // DAILY | WEEKLY | MONTHLY | YEARLY
  reportEmail     String?
  lastReportAt    DateTime?
  lastReportHash  String?
  // DATEV-Export (Übergabekorb → Fibu, Stefan 2026-07-08): Beraternummer/
  // Mandantennummer/Kontenrahmen sind je Mandant unterschiedlich (eigener
  // Steuerberater), daher hier statt in den globalen Betreiber-Einstellungen.
  // Erster Entwurf mit einem Sammelkonto für alle Lieferanten (Stefans Wahl)
  // — die weitere Kontierung je Lieferant bleibt Aufgabe der Fibu in DATEV.
  datevBeraternr       String?
  datevMandantnr       String?
  datevSkr             String? // SKR03 | SKR04 — nur Beschriftung/Doku, keine Kontenlogik
  datevSachkontenlaenge Int?    @default(4)
  datevKreditorenkonto String? // Sammelkonto für alle Kreditoren (Feld "Konto")
  datevGegenkonto      String? // Sammel-Gegenkonto (Feld "Gegenkonto", z. B. Wareneingang/Kosten)
  datevWjBeginn        String? // Wirtschaftsjahr-Beginn als TTMM, z. B. "0101"
  // Optional zusätzlich zum CSV-Sammel-Export: eine EINZELNE E-Mail je Beleg
  // an die Fibu, mit dem Original-Beleg (PDF/Bild) im Anhang — für den Fall,
  // dass die Fibu die Dokumente selbst sehen will/muss, nicht nur die
  // Buchungsdaten aus dem DATEV-CSV (Stefan 2026-07-08).
  datevFibuEmail       String?
  // Kostenstellen/Kostenträger (Stefan 2026-07-09, #114): optionale, im
  // Mandanten-Stamm abschaltbare Buchungsdimension — genau wie bei den
  // Lieferanten-Konten oben wird eine Liste (Code+Bezeichnung) importiert,
  // aus der beim Bearbeiten einer Rechnung ausgewählt werden kann (siehe
  // CostCode/Invoice.costCenterCode/costCarrierCode). Bei "aus" bleibt die
  // Auswahl in der Rechnung ausgeblendet, bereits gesetzte Werte gehen dabei
  // nicht verloren.
  costCentersEnabled Boolean @default(false)
  costCodes          CostCode[]
  // Zähler für eindeutige Dokumenten-IDs (<Slug>-<laufende Nummer>, siehe
  // lib/docId.ts und Invoice.docId) — atomar hochgezählt, damit auch bei
  // gleichzeitigen Uploads keine Doppelvergabe entsteht.
  nextDocSeq       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  users            User[]
  invoices         Invoice[]
  apiTokens        ApiToken[]
  baskets          Basket[]
  vendorAccounts   VendorAccount[]
}

// ── Optionale Verknüpfung vorhandener Fibu-Konten zu Lieferanten (Stefan
// 2026-07-08): per CSV-Import befüllbar (z. B. Export der Kreditoren-
// Stammdaten aus DATEV/der Fibu). Beim DATEV-Export wird für einen
// Lieferanten dieses Konto verwendet, wenn der Name übereinstimmt — sonst
// gilt weiterhin das Sammelkonto (Tenant.datevKreditorenkonto). Komplett
// optional, ohne Import bleibt alles beim Sammelkonto-Verhalten von v1.
model VendorAccount {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendorName String // Abgleich mit Invoice.vendor, case-insensitiv/exakt
  konto      String // DATEV-Kontonummer für diesen Lieferanten
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, vendorName])
}

// ── Kostenstellen/Kostenträger (Stefan 2026-07-09, #114) ── optionale,
// abschaltbare Buchungsdimension, genau wie VendorAccount per CSV-Import
// befüllbar (Code;Bezeichnung). Ein Code wird auf der Rechnung als einfacher
// STRING gespeichert (Invoice.costCenterCode/costCarrierCode), nicht als
// Fremdschlüssel — wird ein Code später aus dieser Liste gelöscht/umbenannt,
// bleibt der historische Buchungswert auf bereits zugeordneten Rechnungen
// unverändert (GoBD: einmal gebuchte Werte nicht rückwirkend verändern).
enum CostCodeKind {
  KOSTENSTELLE
  KOSTENTRAEGER
}

model CostCode {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      CostCodeKind
  code      String
  name      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([tenantId, kind, code])
  @@index([tenantId, kind])
}

// ── Sicherungspakete (Stefan 2026-07-08) ── ZIP-Datei einer Sicherung
// (Mandant oder Gesamtsystem), serverseitig abgelegt mit SHA-256-Prüfsumme.
// Die Zustell-E-Mail enthält nur den Download-Link (downloadToken) statt des
// Pakets selbst; runBackupReminders() erinnert, solange nicht heruntergeladen
// und innerhalb von tenant.backupReminderDays.
model BackupPackage {
  id             String    @id @default(cuid())
  tenantId       String? // null = System-Sicherung (alle Mandanten)
  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind           String // TENANT | SYSTEM
  fileName       String // gespeicherter Dateiname unter backup-packages/{tenantId|system}/
  originalName   String // Downloadname für den Nutzer (…-<hash8>.zip)
  sha256         String
  sizeBytes      Int
  downloadToken  String    @unique
  createdAt      DateTime  @default(now())
  expiresAt      DateTime
  downloadedAt   DateTime?
  lastReminderAt DateTime?
  reminderCount  Int       @default(0)
  // Ergebnis des optionalen zusätzlichen WebDAV-Uploads (Tenant.backupWebdavUrl)
  remoteStoredAt DateTime?
  remoteError    String?

  @@index([tenantId, createdAt])
  @@index([downloadedAt])
}

// ── API-Token für die Browser-Extension (Rechnungs-Catcher) ──
model ApiToken {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label      String
  tokenHash  String    @unique // SHA-256 des Tokens — Klartext wird nie gespeichert
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

// ── Benutzer (§2) ──
model User {
  id              String    @id @default(cuid())
  tenantId        String? // null = Betreiber-Administrator
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String
  username        String    @unique // global eindeutiger technischer Name
  passwordHash    String
  // Stammdaten (Stefan 2026-07-08): für Mitarbeiter-Übersicht, Anrede in
  // Mails und Zuordnung in Körben — alle optional, da Bestandsnutzer sie
  // noch nicht haben.
  firstName       String?
  lastName        String?
  department      String? // Abteilung
  jobTitle        String? // Funktion
  role            Role      @default(USER)
  active          Boolean   @default(true)
  language        String    @default("de")
  twoFactorSecret String? // reserviert (MVP: 2FA nicht aktiv)
  createdAt       DateTime  @default(now())
  lastLoginAt     DateTime?
  lastSeenAt      DateTime?
  forcedLogoutAt  DateTime? // Zwangsabmeldung-ab (§10)
  invoices        Invoice[]
  basketMemberships BasketMember[]
  basketApprovals   BasketApproval[]
  basketRights      BasketUserRight[]
  uploadedAttachments   InvoiceAttachment[]
  notesAuthored         InvoiceNote[]       @relation("InvoiceNoteAuthor")
  notesReceived         InvoiceNote[]       @relation("InvoiceNoteRecipient")

  // E-Mail ist PRO MANDANT eindeutig, nicht global (§2)
  @@unique([tenantId, email])
  @@index([email])
}

// ── Betreiber-Systemeinstellungen (§24), Schlüssel/Wert ──
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── Revisionssichere Protokollierung mit Hash-Kette (§18) ──
model AuditLog {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  tenantId  String?
  actorId   String?
  actorName String
  action    String
  details   String?
  ip        String? // nur wenn Mandant zugestimmt hat (§18)
  prevHash  String
  hash      String

  @@index([tenantId, createdAt])
}

// ── Fernwartung §14A: eingebaute Bildschirmspiegelung (ohne externe Software) ──
enum SupportStatus {
  REQUESTED // angefragt
  ACTIVE    // aktiv (Einwilligung erteilt)
  ENDED     // beendet
  DECLINED  // abgelehnt
}

model SupportSession {
  id          String        @id @default(cuid())
  tenantId    String
  userId      String? // Nutzer, dessen Sicht gespiegelt wird (bei Betreiber-Anfrage erst nach Einwilligung)
  initiatedBy String // 'TENANT' | 'OPERATOR'
  status      SupportStatus @default(REQUESTED)
  createdAt   DateTime      @default(now())
  startedAt   DateTime?
  endedAt     DateTime?
  endedBy     String?
  snapshot    String? // letzter DOM-Spiegel (maskiert, ohne Skripte)
  snapshotAt  DateTime?

  @@index([tenantId, status])
}

// ── E-Mail-Eingang (Weiterleitungs-Modell W1/W2): Protokoll aller Eingänge & Versuche ──
model MailIntake {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  tenantId    String? // null = keinem Mandanten zuordenbar (Fehlversuch)
  fromAddress String
  toAddress   String
  subject     String?
  status      String // PROCESSED | NO_ATTACHMENT | UNKNOWN_RECIPIENT | TENANT_LOCKED | ERROR
  detail      String?
  invoiceId   String?

  @@index([tenantId, createdAt])
  @@index([createdAt])
}

// ── Körbe (Rechnungseingangsverarbeitung, Stefan 2026-07-08): Rechnungen
// wandern durch benannte "Körbe" (wie E-Mail-Postfach-Ordner) statt einer
// einzigen flachen Liste. Jeder Mandant hat automatisch genau einen
// Eingangskorb (kind=INBOX, wo neu erfasste Rechnungen zuerst landen) und
// einen Übergabekorb (kind=HANDOVER, Endstation vor Export/Buchhaltung) —
// beide werden bei Bedarf automatisch angelegt (siehe lib/baskets.ts
// ensureSystemBaskets). Dazwischen beliebig viele frei anlegbare Körbe
// (kind=CUSTOM). Vier-Augen-Prinzip ist für INBOX/HANDOVER serverseitig
// gesperrt (dort macht ein zusätzliches Freigabe-Gate konzeptionell keinen
// Sinn — Eingang ist offen, Übergabe ist bereits das Ergebnis der Kette).
enum BasketKind {
  INBOX
  HANDOVER
  CUSTOM
  // Ablage (Stefan 2026-07-09): fester Systemordner, in den Rechnungen nach
  // vollständiger Übergabe automatisch wandern und dort bleiben. Nur
  // Mandanten-Admin/Betreiber dürfen Belege von dort wieder herausverschieben
  // — Korb-Rechte MOVE und höher lassen sich für ARCHIVE-Körbe gar nicht erst
  // vergeben (siehe admin/baskets/[id]/rights/route.ts).
  ARCHIVE
}

model Basket {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  kind      BasketKind @default(CUSTOM)
  position  Int        @default(0) // Reihenfolge in der Anzeige/Kette
  // Vier-Augen-Prinzip: EIGENES Gate beim Verlassen dieses Korbs (unabhängig
  // von der Rechnungsprüfung/4-Häkchen auf der Rechnung selbst) — zwei
  // UNTERSCHIEDLICHE Mitarbeiter müssen den Korb-Wechsel freigeben, bevor er
  // ausgeführt wird. Serverseitig erzwungen: bei kind IN (INBOX, HANDOVER)
  // immer false, nicht änderbar.
  fourEyesEnabled   Boolean @default(false)
  // Sammel-Benachrichtigung statt einer Mail pro Rechnung: läuft im
  // Scheduler (lib/baskets.ts runDueBasketNotifications, wie backup/report)
  // und schickt je fälligem Intervall EINE Übersichtsmail pro zugeordnetem
  // Mitarbeiter mit den aktuell im Korb liegenden Rechnungen.
  notificationEnabled       Boolean   @default(false)
  notificationIntervalHours Int?      // frei wählbares Intervall in Stunden
  lastNotifiedAt            DateTime?
  // Weiches Löschen (Stefan 2026-07-08): nur leere eigene Körbe löschbar (siehe
  // DELETE-Route), landen dann im "Papierkorb für Körbe" und lassen sich
  // wiederherstellen — analog zum Rechnungs-Papierkorb.
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   BasketMember[]
  invoices  Invoice[]
  approvals BasketApproval[]
  userRights BasketUserRight[]

  @@index([tenantId, kind])
}

// ── Korb-Rechte je Rolle (Stefan 2026-07-08) ── Nur der Mandanten-Admin
// (und der Betreiber, der immer alle Rechte hat) kann diese Zuordnung in der
// Körbe-Verwaltung ändern. Für Rollen ohne Eintrag gilt: KEIN Zugriff auf
// diesen Korb (auch nicht "sehen"). Sechsstufige Rangfolge, jede Stufe
// schließt alle darunter liegenden ein (siehe lib/basketRights.ts RIGHT_RANK):
// sehen < Inhalt anzeigen < verschieben < sachlich freigeben <
// Übergabe an den Übergabekorb < Übergabe an die Fibu.
enum BasketRight {
  VIEW     // Korb wird überhaupt angezeigt
  CONTENT  // Rechnungsinhalt im Korb einsehen
  MOVE     // Rechnungen in/aus diesem Korb verschieben
  APPROVE  // "Sachlich richtig" auf Rechnungen in diesem Korb freigeben
  HANDOVER // Übergabe einer Rechnung an den (festen) Übergabekorb
  FIBU     // Übergabe an die Fibu auslösen (DATEV-Export/Einzel-Mail)
}

// Stefan 2026-07-08: ursprünglich rollenbasiert (BasketRolePermission) — auf
// Wunsch von Stefan direkt auf Mitarbeiter-Auswahl umgestellt, da die
// Rollen-Zuordnung in der Praxis nur verwirrt hat. Jede Zeile = ein
// Mitarbeiter mit einem Recht auf einem Korb; ohne Zeile = kein Zugriff.
model BasketUserRight {
  id        String      @id @default(cuid())
  basketId  String
  basket    Basket      @relation(fields: [basketId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  right     BasketRight
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([basketId, userId])
}

// Mitarbeiter-Zuordnung zu einem Korb (wer ist zuständig / wird benachrichtigt)
model BasketMember {
  id        String   @id @default(cuid())
  basketId  String
  basket    Basket   @relation(fields: [basketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([basketId, userId])
}

// Vier-Augen-Freigaben für einen konkreten Korb-Wechsel (Rechnung X, von Korb
// A nach Korb B). Bei der zweiten Freigabe eines ANDEREN Mitarbeiters für
// dieselbe Kombination wird der Wechsel automatisch ausgeführt und alle
// offenen Freigaben für diese Rechnung/diesen Ausgangskorb gelöscht
// (siehe lib/baskets.ts approveMove).
model BasketApproval {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fromBasketId   String
  fromBasket     Basket   @relation(fields: [fromBasketId], references: [id], onDelete: Cascade)
  targetBasketId String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@unique([invoiceId, fromBasketId, targetBasketId, userId])
}

// ── Einmal-Tickets für Identitätsübernahme (§12) ──
model LoginTicket {
  id               String    @id @default(cuid())
  code             String    @unique
  targetUserId     String
  impersonatorId   String?
  impersonatorName String?
  expiresAt        DateTime
  usedAt           DateTime?
}

// ── Rechnung (E-Invoice Kernentität, mandantengetrennt) ──
model Invoice {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Eindeutige, lesbare Dokumenten-ID (<Slug>-<laufende Nummer>, z. B.
  // "musterfirma-000001") — für GoBD-Referenzierung außerhalb der internen
  // cuid. Nullable für Bestandsdaten vor Einführung dieses Felds (Backfill
  // per scripts/backfill-doc-ids.ts), danach immer gesetzt.
  docId         String?       @unique
  // Körbe (Rechnungseingangsverarbeitung): aktueller Korb, in dem die
  // Rechnung liegt. Nullable für Bestand vor Einführung — Backfill setzt
  // den Eingangskorb (siehe scripts/backfill-baskets.ts).
  basketId      String?
  basket        Basket?       @relation(fields: [basketId], references: [id], onDelete: SetNull)
  basketApprovals BasketApproval[]
  vendor        String
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  amountNet     Decimal?      @db.Decimal(12, 2)
  amountTax     Decimal?      @db.Decimal(12, 2)
  amountGross   Decimal?      @db.Decimal(12, 2)
  currency      String        @default("EUR")
  status        InvoiceStatus @default(NEW)
  tags          String?
  notes         String?
  fileName      String? // gespeicherter Dateiname unter uploads/{tenantId}/
  originalName  String?
  mimeType      String?
  encrypted     Boolean @default(false) // Datei liegt als Chiffrat (IV + AES-GCM)
  encOrigMime   String? // ursprünglicher MIME-Typ (für Anzeige nach Entschlüsselung)
  // Inhalts-Verschlüsselung (Stefan 2026-07-09): bei aktiver Mandanten-
  // Verschlüsselung wird NICHT mehr nur die Beleg-Datei, sondern auch der
  // inhaltliche Teil der Rechnungsdaten client-seitig verschlüsselt — Server
  // sieht auch hier nur Chiffrat. contentEnc enthält ein einziges AES-GCM-
  // Chiffrat (Base64, IV+Ciphertext, wie bei der Datei) eines JSON-Objekts
  // mit { vendor, invoiceNumber, amountNet, amountTax, amountGross, currency,
  // tags, notes, xmlData }. Die gleichnamigen Einzelspalten bleiben bei
  // verschlüsselten Rechnungen leer/Platzhalter (vendor bekommt einen festen
  // Platzhalter-Text statt NULL, da NOT NULL) — NICHT der wahre Inhalt.
  // Workflow-Felder (dueDate, status, checkXxxAt/By, directDebitByVendor)
  // bleiben bewusst im Klartext, damit Fälligkeits-Erinnerungen, Körbe-Zähler
  // und die Rechnungsprüfung serverseitig weiter funktionieren. Suche/
  // Sortierung nach Lieferant/Beträgen sowie der DATEV-Export müssen für
  // verschlüsselte Mandanten client-seitig laufen (Folgearbeit, siehe Task
  // #101/#102) — hier wird zunächst nur das Datenmodell dafür vorbereitet.
  contentEnc    String?
  // Kostenstellen/Kostenträger (Stefan 2026-07-09, #114): optionale
  // Buchungsdimension, nur nutzbar wenn Tenant.costCentersEnabled — als
  // freier Code-String statt Fremdschlüssel gespeichert (siehe CostCode-
  // Kommentar oben, GoBD-Grund). Workflow-Feld, bleibt IMMER im Klartext,
  // auch bei aktiver Inhalts-Verschlüsselung (wie dueDate/status).
  costCenterCode  String?
  costCarrierCode String?
  // Dubletten-Prüfung: Datei-Hash + Verweis auf das erkannte Original
  fileHash      String? // SHA-256 der Beleg-Datei
  duplicateOfId String? // gesetzt = als Dublette erkannt
  // KI-Datenerkennung: true = mindestens ein Feld wurde per KI übernommen
  // (Erstauswahl beim Scannen oder nachträglich auf der Detailseite), sonst
  // von Hand erfasst — sichtbar in der Rechnungsliste (source = "SCAN" +
  // aiAssisted zusammen zeigen dort Herkunft/Erfassungsart).
  aiAssisted    Boolean @default(false)
  // E-Rechnung (W17): erkanntes Format + Prüfergebnis + XML für die Visualisierung
  docFormat        String? // ZUGFERD | XRECHNUNG_CII | XRECHNUNG_UBL | PDF | OTHER
  xmlData          String? // eingebettetes/originales Rechnungs-XML
  validationOk     Boolean? // Pflichtfeld-Prüfung (EN 16931-Kern) bestanden?
  validationIssues String? // fehlende Pflichtangaben (kommagetrennt)
  // Rechnungsprüfung (klassischer 4-Augen-Workflow): je Schritt wer + wann
  // geprüft hat — gesetzt = erledigt, null = offen. Vom Server gestempelt
  // (angemeldeter Nutzer), nicht vom Client frei setzbar.
  checkElectronicAt  DateTime? // Elektronische Vorprüfung
  checkElectronicBy  String?
  checkFormalAt      DateTime? // Formal richtig
  checkFormalBy      String?
  checkSubstantiveAt DateTime? // Sachlich richtig
  checkSubstantiveBy String?
  checkAccountingAt  DateTime? // An Buchhaltung übergeben
  checkAccountingBy  String?
  // Zahlungsart: Lieferant zieht den Betrag selbst per Lastschrift/Abbuchung
  // ein (statt Überweisung durch uns)
  directDebitByVendor Boolean @default(false)
  source        String        @default("UPLOAD")
  // "Löschen" markiert nur — echtes Entfernen widerspräche der revisionssicheren
  // Nachvollziehbarkeit (GoBD). Gelöschte Rechnungen verschwinden aus der
  // normalen Liste, bleiben aber (inkl. Beleg-Datei) erhalten und lassen sich
  // wiederherstellen.
  deletedAt     DateTime?
  deletedBy     String?
  createdById   String?
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  attachments   InvoiceAttachment[]
  messages      InvoiceNote[]

  @@index([tenantId, status])
  @@index([tenantId, invoiceDate])
  @@index([tenantId, fileHash])
  @@index([tenantId, deletedAt])
  @@index([basketId])
}

// ── Zusätzliche Dokumente zu einer Rechnung (Stefan 2026-07-08): neben dem
// eigentlichen Beleg lassen sich jederzeit weitere Dateien anhängen (z. B.
// Lieferschein, Vertrag, Mail-Verlauf, Bestellung) — unabhängig vom
// Haupt-Beleg und dessen GoBD-Sperre bei E-Rechnungen (Anhänge sind reine
// Zusatzinformation, keine Rechnungsdaten, daher jederzeit hinzufügbar/
// löschbar, auch bei ZUGFeRD/XRechnung). Nutzt denselben Datei-Speicher wie
// der Hauptbeleg (lib/storage.ts), aber OHNE Zero-Knowledge-Verschlüsselung
// (v1) — bei aktiver Beleg-Verschlüsselung des Mandanten wird der Upload
// serverseitig gesperrt, um keine unverschlüsselten sensiblen Anhänge neben
// verschlüsselten Belegen abzulegen.
model InvoiceAttachment {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId     String
  fileName     String // gespeicherter Dateiname unter uploads/{tenantId}/
  originalName String
  mimeType     String
  size         Int
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([invoiceId])
}

// ── Gerichtete Nachricht an einen Mitarbeiter (Stefan 2026-07-08): anders
// als das freie Notizfeld (Invoice.notes, z. B. Kontierung) ist dies eine
// ADRESSIERTE Nachricht an einen bestimmten Kollegen — z. B. "bitte
// Kostenstelle prüfen, betrifft Projekt X" — wichtig für dessen nächsten
// Bearbeitungsschritt. Mehrere Nachrichten pro Rechnung möglich (kleiner
// Verlauf statt Überschreiben), mit Lese-Status.
model InvoiceNote {
  id        String    @id @default(cuid())
  invoiceId String
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId  String
  authorId  String?
  author    User?     @relation("InvoiceNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  toUserId  String?
  toUser    User?     @relation("InvoiceNoteRecipient", fields: [toUserId], references: [id], onDelete: SetNull)
  text      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([invoiceId])
  @@index([toUserId, readAt])
}
