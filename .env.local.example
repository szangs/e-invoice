# ── E-Invoice — lokale Konfiguration ──
# Diese Datei nach .env.local kopieren und Werte eintragen.
# .env.local wird NIEMALS eingecheckt.

# Anzeigename der Anwendung (Umbenennung = nur diese Zeilen ändern)
APP_NAME=E-Invoice
APP_NAME_SHORT=E-Invoice
APP_COMPANY=deltaplus GmbH

# PostgreSQL (DP-Standard)
# Format: postgresql://BENUTZER:PASSWORT@localhost:5432/DATENBANK?schema=public
DATABASE_URL=postgresql://postgres:PASSWORT@localhost:5432/einvoice?schema=public

# next-auth
# Secret erzeugen (PowerShell):  [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
NEXTAUTH_SECRET=HIER-SECRET-EINTRAGEN
NEXTAUTH_URL=http://localhost:3000

# Seed: Passwort des Betreiber-Administrators (nur für npx prisma db seed)
SEED_OPERATOR_EMAIL=stefan.zangs@deltaplus.de
SEED_OPERATOR_PASSWORD=HIER-STARTPASSWORT-EINTRAGEN
